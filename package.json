{
	"name": "summit-kit",
	"description": "A React component library for building modern web applications with an earthy and outdoorsy flair.",
	"version": "3.5.3",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/react/index.d.ts",
			"import": "./dist/react/index.js"
		},
		"./react": {
			"types": "./dist/react/index.d.ts",
			"import": "./dist/react/index.js"
		},
		"./svelte": {
			"types": "./dist/svelte/index.d.ts",
			"svelte": "./dist/svelte/index.js",
			"import": "./dist/svelte/index.js"
		},
		"./styles": "./dist/summit-kit.css",
		"./styles/global": "./dist/global.css",
		"./styles/colors": "./dist/colors.css"
	},
	"files": [
		"dist",
		"!**/*.tsbuildinfo"
	],
	"sideEffects": [
		"**/*.css",
		"**/*.module.css"
	],
	"peerDependencies": {
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"svelte": "^5.0.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		},
		"svelte": {
			"optional": true
		}
	},
	"simple-git-hooks": {
		"pre-commit": "npx simple-git-hooks && npx tsc --noEmit && npx lint-staged"
	},
	"lint-staged": {
		"src/**/*.{ts,tsx,css,md}": [
			"npx @biomejs/biome check --write ./src"
		],
		"src/**/*.{ts,tsx}": [
			"npx vitest related --run"
		]
	},
	"scripts": {
		"prepare": "npm run build && npx simple-git-hooks",
		"clean": "rimraf dist storybook-static",
		"gen-tokens": "node --experimental-strip-types scripts/gen-tokens.ts",
		"build:react": "vite build",
		"build:shared-css": "node --experimental-strip-types scripts/copy-shared-css.ts",
		"build:svelte": "svelte-package --input src/svelte --output dist/svelte --tsconfig tsconfig.svelte.json",
		"build": "npm run build:react && npm run build:shared-css && npm run build:svelte",
		"storybook": "storybook dev -p 6006",
		"test": "vitest",
		"build-storybook": "storybook build -o storybook-static"
	},
	"dependencies": {
		"lucide-react": "^1.24.0",
		"screenfull": "^6.0.2",
		"shiki": "^4.3.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@lucide/svelte": "^1.24.0",
		"@storybook/addon-a11y": "^10.5.0",
		"@storybook/react": "^10.5.0",
		"@storybook/react-vite": "^10.5.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"conventional-changelog": "^8.1.0",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.8",
		"rimraf": "^6.1.3",
		"rollup-preserve-directives": "^1.1.3",
		"simple-git-hooks": "^2.13.1",
		"storybook": "^10.5.0",
		"svelte": "^5.56.5",
		"svelte-check": "^4.7.3",
		"typescript": "^6.0.3",
		"vite": "^8.1.4",
		"vite-plugin-dts": "^5.0.3",
		"vitest": "^4.1.10"
	},
	"keywords": [
		"react",
		"kit",
		"components",
		"ui",
		"library",
		"summit"
	],
	"homepage": "https://summit-kit.gremlich.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/andrewgremlich/summit-kit.git"
	}
}
