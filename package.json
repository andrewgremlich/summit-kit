{
	"name": "summit-kit",
	"description": "A React component library for building modern web applications with an earthy and outdoorsy flair.",
	"version": "3.5.2",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/react/server/index.d.ts",
			"import": "./dist/react-server.js"
		},
		"./server": {
			"types": "./dist/react/server/index.d.ts",
			"import": "./dist/react-server.js"
		},
		"./client": {
			"types": "./dist/react/client/index.d.ts",
			"import": "./dist/react-client.js"
		},
		"./styles": "./dist/summit-kit.css",
		"./styles/global": "./dist/global.css",
		"./styles/colors": "./dist/colors.css"
	},
	"files": [
		"dist",
		"!**/*.tsbuildinfo"
	],
	"peerDependencies": {
		"react": "^19.1.0",
		"react-dom": "^19.1.0"
	},
	"simple-git-hooks": {
		"pre-commit": "npx simple-git-hooks && npx tsc --noEmit && npx lint-staged"
	},
	"lint-staged": {
		"src/**/*.{ts,tsx,css,md}": [
			"npx @biomejs/biome check --write ./src"
		],
		"src/**/*.{ts,tsx}": [
			"npx vitest related --run"
		]
	},
	"scripts": {
		"prepare": "npm run build && npx simple-git-hooks",
		"clean": "rimraf dist storybook-static",
		"build": "vite build",
		"storybook": "storybook dev -p 6006",
		"test": "vitest",
		"build-storybook": "storybook build -o storybook-static"
	},
	"dependencies": {
		"lucide-react": "^1.16.0",
		"prism-react-renderer": "^2.4.1",
		"screenfull": "^6.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@storybook/addon-a11y": "^10.4.0",
		"@storybook/react": "^10.4.0",
		"@storybook/react-vite": "^10.4.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.9.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"conventional-changelog": "^7.2.0",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.5",
		"rimraf": "^6.1.3",
		"simple-git-hooks": "^2.13.1",
		"storybook": "^10.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.13",
		"vite-plugin-dts": "^5.0.0",
		"vitest": "^4.1.6"
	},
	"keywords": [
		"react",
		"kit",
		"components",
		"ui",
		"library",
		"summit"
	],
	"homepage": "https://summit-kit.gremlich.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/andrewgremlich/summit-kit.git"
	}
}
