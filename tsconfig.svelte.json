{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"types": ["svelte"],
		"module": "preserve",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": false,
		"verbatimModuleSyntax": false,
		"noEmit": false,
		"declaration": true,
		"emitDeclarationOnly": true
	},
	"include": ["src/svelte/**/*", "src/shared/**/*", "src/types/**/*"]
}
